PORT=5001
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/datad?retryWrites=true&w=majority
JWT_SECRET=<long-random-string>
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>
RESEND_API_KEY=<resend-api-key>
MAIL_FROM=<verified-sender-domain-from-address>
ADMIN_EMAIL=<the-admin-superuser-email>
# ── AI providers ──────────────────────────────────────────────────────────────
# Primary provider — NVIDIA NIM (set at least this key)
NVIDIA_API_KEY=<nvidia-nim-api-key>
# Optional second key (different NVIDIA account) — used automatically when
# the primary key hits a 401/429 account-level failure.
NVIDIA_API_KEY_FALLBACK=
NVIDIA_MODEL=

# Local fallback (no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Legacy providers (preserved for backward compatibility)
GROQ_API_KEY=
GROQ_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Which provider to use first and as fallback
AI_PRIMARY_PROVIDER=nvidia
AI_FALLBACK_PROVIDER=ollama

# ── AI automation thresholds ──────────────────────────────────────────────────
# Content with confidence >= AUTO_PUBLISH is published immediately; below MINIMUM is discarded
AI_CONFIDENCE_AUTO_PUBLISH=0.75
AI_CONFIDENCE_MINIMUM=0.4
MODERATION_HIDE_THRESHOLD=0.85
MODERATION_BATCH_SIZE=20

# ── Cron schedule overrides (node-cron format, optional) ──────────────────────
# CRON_DAILY_CASE=0 5 * * *
# CRON_DAILY_BRIEFING=0 6 * * *
# CRON_DAILY_REFLECTION=15 6 * * *
# CRON_RESUME_TIP=0 7 * * *
# CRON_COMPANY_REFRESH=0 2 * * *
# CRON_INTERVIEW_QUESTIONS=0 4 * * 0
# CRON_NEWSLETTER=0 8 * * 0
# CRON_NEWS_REFRESH=*/30 * * * *
# CRON_MARKET_REFRESH=*/15 * * * *
# CRON_MODERATION=*/10 * * * *

# ── Resume tip deduplication window ──────────────────────────────────────────
RESUME_TIP_DEDUP_DAYS=60

# ── AI Orchestration Platform (Phase 2-12) ───────────────────────────────────

# Semantic search — uses OpenAI text-embedding-3-small when key is set,
# falls back to a zero-dependency hash-based vector otherwise
# OPENAI_API_KEY already covers embeddings — no extra key needed

# Model routing tiers (override defaults from ai/router.js if needed)
# AI_FAST_PROVIDER=groq          # cheap summarization
# AI_BALANCED_PROVIDER=openai    # structured JSON tasks
# AI_POWERFUL_PROVIDER=anthropic # complex reasoning

# AI retry tuning
AI_RETRY_ATTEMPTS=3
AI_RETRY_DELAY_MS=2000

# News content age ceiling (days before pruning)
NEWS_MAX_AGE_DAYS=21
# ── Subscription / UPI ────────────────────────────────────────────────────────
# These are read by the CLIENT as VITE_ vars — put the same values in client/.env
# UPI VPA and display name shown on the payment QR
# (Set in client/.env as VITE_UPI_VPA and VITE_UPI_NAME)

# Content Studio (centralized publishing). Set to false to disable.
STUDIO_ENABLED=true
